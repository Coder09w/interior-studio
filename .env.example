# Interior Studio — Environment Variables
# Copy this file to .env and fill in the values

# Database — PostgreSQL (Neon / Supabase / any Postgres provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# NextAuth — MUST change in production
NEXTAUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
NEXTAUTH_URL=https://instod.vercel.app

# Beta Mode — When true, all users get Pro features for free
# Stripe checkout is disabled. Set to false when launching paid plans.
NEXT_PUBLIC_BETA_MODE=true

# Stripe — Payment processing (DISABLED during beta)
# When ready to launch paid plans:
#   1. Set NEXT_PUBLIC_BETA_MODE=false
#   2. Run: npx tsx scripts/setup-stripe.ts
#   3. The script creates products/prices/webhook and fills these in:
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email (for password reset flow) — configure your provider
# EMAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
