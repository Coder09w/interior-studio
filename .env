# Beta Mode — When true, all users get Pro features for free
# Stripe checkout is disabled. Set to false when launching paid plans.
NEXT_PUBLIC_BETA_MODE=true

# Stripe — Payment processing (DISABLED during beta)
# Set these by running: npx tsx scripts/setup-stripe.ts
# The script will auto-fill them after creating products/prices in Stripe.
# For manual setup, get keys from: https://dashboard.stripe.com/apikeys
# When BETA_MODE=false, uncomment these and fill in real values:
# STRIPE_SECRET_KEY=sk_test_placeholder
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
# NEXT_PUBLIC_STRIPE_STUDIO_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=

# Z-AI SDK Configuration — Used by /api/ai-render for AI image generation
# These are read by the API route directly, bypassing the .z-ai-config file
ZAI_BASE_URL=https://internal-api.z.ai/v1
ZAI_API_KEY=Z.ai
ZAI_CHAT_ID=
ZAI_USER_ID=
ZAI_TOKEN=
