// This is your Prisma schema file,
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  studio
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  plan          Plan      @default(free)
  onboarding    Boolean   @default(false) // has completed onboarding
  defaultRoomW  Float     @default(8)
  defaultRoomD  Float     @default(6)
  defaultRoomH  Float     @default(3)
  defaultWallColor String @default("#FAF8F4")
  autoSave      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  projects     Project[]
  subscription Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String  @id @default(cuid())
  sessionToken String  @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  status               String   @default("active") // active, past_due, canceled, incomplete, trialing
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlanConfig {
  id                  String   @id @default(cuid())
  planKey             String   @unique // "free", "pro", "studio"
  name                String   // Display name
  price               Float    @default(0) // Monthly price in USD
  priceId             String   @default("") // Stripe Price ID
  description         String   @default("")
  highlight           Boolean  @default(false)
  cta                 String   @default("")

  // Limits (null = unlimited)
  maxProjects         Int?
  maxRoomsPerProject  Int?
  maxFurniturePerRoom Int?
  maxRevisionSnapshots Int?   // null = unlimited
  maxMoodBoards       Int?   // null = unlimited

  // Feature flags (stored as JSON string for flexibility)
  features            String   @default("{}") // JSON: { allFurnitureItems: bool, revisionSnapshots: bool, ... }

  // Free-tier restrictions (stored as JSON)
  freeRoomTypes       String   @default("[]") // JSON array: ["living", "bedroom", ...]
  freeLightingMoods   String   @default("[]") // JSON array: ["daylight", "evening"]
  allRoomTypes        String   @default("[]") // JSON array of all room types
  allLightingMoods    String   @default("[]") // JSON array of all lighting moods

  // Feature comparison for pricing page (stored as JSON)
  featureComparison   String   @default("[]") // JSON array of comparison categories

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String   @default("My House")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms  Room[]
}

model Room {
  id          String   @id @default(cuid())
  name        String   @default("Living Room")
  roomType    String   @default("living") // living, bedroom, kitchen, bathroom, office, dining
  width       Float    @default(8)
  depth       Float    @default(6)
  height      Float    @default(3)
  wallColor   String   @default("#FAF8F4")
  floorType   String   @default("hardwood") // hardwood, marble, concrete, carpet, tile
  doorWall    String   @default("none") // none, back, left, right
  windowCount Int      @default(1)
  windowWall  String   @default("back") // back, left, right
  lightMood   String   @default("daylight") // daylight, golden, evening, night
  furniture   String   @default("[]") // JSON array of furniture items
  thumbnail   String?
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([id])
}
